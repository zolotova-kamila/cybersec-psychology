# Enable compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Enable browser caching
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Images
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    
    # CSS and JavaScript
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    
    # Fonts
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    
    # HTML
    ExpiresByType text/html "access plus 1 hour"
</IfModule>

# Cache-Control headers
<IfModule mod_headers.c>
    <FilesMatch "\.(jpg|jpeg|png|gif|svg|webp|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
    
    <FilesMatch "\.(woff|woff2|ttf|otf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

# Disable ETags
<IfModule mod_headers.c>
    Header unset ETag
</IfModule>
FileETag None

# 301 Redirects for removed pages (old site structure)
Redirect 301 /psihoterapiya/ https://pozitiv-psychology.ru/
Redirect 301 /semejnye-otnosheniya/ https://pozitiv-psychology.ru/
Redirect 301 /konsultirovanie/ https://pozitiv-psychology.ru/
Redirect 301 /obshhaya-psixologiya/ https://pozitiv-psychology.ru/

# 301 Redirects for moved articles (old → new URLs)
Redirect 301 /article-alert-fatigue.html https://pozitiv-psychology.ru/articles/trevozhnoye-utomleniye.html
Redirect 301 /article-pochemu-umnye-lyudi-popadayutsya-na-moshennikov.html https://pozitiv-psychology.ru/articles/pochemu-umnye-lyudi-popadayutsya.html
Redirect 301 /article-vosstanovlenie-posle-moshennichestva.html https://pozitiv-psychology.ru/articles/vosstanovlenie-posle-moshennichestva.html
Redirect 301 /test.html https://pozitiv-psychology.ru/articles/test.html